# Optional per-server overrides for the deploy scripts.
# Copy to `deploy.env` in the deploy directory ON THE SERVER and edit as needed.
# Everything here has a sensible default — you usually don't need this file.

# Paths to the binaries (defaults: alongside the scripts).
#GANG_BIN=/opt/gang-chat/gang-server
#LIVEKIT_BIN=/opt/gang-chat/livekit-server
#LIVEKIT_CONFIG=/opt/gang-chat/livekit.yaml

# Where logs and pid files go (defaults: ./logs and ./run).
#LOG_DIR=/var/log/gang-chat
#RUN_DIR=/run/gang-chat

# Keep COS credentials and asset public base URL in `.env` or a secret manager,
# not in this file.

# Optional: expose client update metadata through GET /api/v1/app/version.
# The default follows the latest client release and reads its app-update.json.
GANG_APP_VERSION_RELEASE_URL=https://loganz2.cn/api/v1/repos/logan/gang-chat-client/releases/latest
# To pin a specific manifest instead, set:
#GANG_APP_VERSION_MANIFEST_URL=https://loganz2.cn/logan/gang-chat-client/releases/download/v0.3.1/app-update.json
#GANG_APP_VERSION_CACHE_TTL_SECONDS=300
